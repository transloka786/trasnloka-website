# ── Required for the public contact form (Resend) ─────────────
# Create a Resend API key and verify the sender domain/address.
RESEND_API_KEY=
CONTACT_TO=hellokritrna@gmail.com
CONTACT_FROM=KritRNA <website@hellokritrna.com>

# ── Optional: recruitment database + résumé storage ───────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional: website chatbot ──────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Canonical public site URL ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.hellokritrna.com
