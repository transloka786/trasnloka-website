# ── Google Workspace SMTP email delivery ─────────────────────────
# Use a real Google Workspace mailbox with 2-Step Verification and a dedicated app password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hello@hellokritrna.com
SMTP_APP_PASSWORD=
CONTACT_FROM=KritRNA Website <hello@hellokritrna.com>

# Optional overrides. These defaults are already coded into the app.
CONTACT_TO=hello@hellokritrna.com
CAREERS_TO=careers@hellokritrna.com
ADMIN_BCC=hellokritrna@gmail.com

# ── Recruitment, analytics, newsletter and operational logs ─────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Website chatbot ──────────────────────────────────────────────
# The key remains server-side. The assistant uses the Responses API,
# moderation, local approved retrieval and—when configured—OpenAI File Search.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Upload the approved public knowledge pack to an OpenAI vector store, then add its ID.
OPENAI_VECTOR_STORE_ID=

# ── Synthetic production-delivery monitoring ────────────────────
# Use the same value as the SYNTHETIC_TEST_SECRET GitHub Actions secret.
SYNTHETIC_TEST_SECRET=

# ── Canonical public site URL ────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.hellokritrna.com
