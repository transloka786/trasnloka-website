# ── Add these only in the final domain-attached Vercel project ──
# Create a Resend API key and verify hellokritrna.com as a sending domain.
RESEND_API_KEY=
CONTACT_FROM=KritRNA Website <website@hellokritrna.com>

# Optional overrides. These defaults are already coded into the app.
CONTACT_TO=hello@hellokritrna.com
CAREERS_TO=careers@hellokritrna.com
ADMIN_BCC=hellokritrna@gmail.com

# ── Optional: recruitment database + résumé storage ───────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Website chatbot ────────────────────────────────────────────
# The key remains server-side. The assistant uses the Responses API,
# omni-moderation-latest, local retrieval and the curated public knowledge base.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ── Canonical public site URL ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.hellokritrna.com
